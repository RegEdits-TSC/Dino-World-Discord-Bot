<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for Dino-World.

  Two appenders share the same content but use different patterns:

    - STDOUT applies ANSI color (Logback's %highlight / %cyan / %boldWhite).
      Works on Linux/macOS terminals, Windows Terminal, PowerShell, and
      cmd.exe on Windows 10 1909+ (virtual terminal sequences are enabled
      by default).
    - FILE keeps the plain pattern so logs/bot.log stays grep-friendly
      (no ANSI escape bytes in the saved files).

  MDC tags: CommandRouter populates a pre-formatted 'tags' key (with a
  LEADING space — e.g. " [ping g=12345 u=67890]") while a command is being
  dispatched, and clears it afterward. The pattern places %X{tags}
  immediately after [%thread] so it follows a plain `]` literal — Logback's
  pattern parser has a quirk where a converter placed immediately after a
  composite converter's closing `)` (like %boldWhite(...) or %highlight(...))
  is not parsed and prints literally.

  Root logger level
  -----------------
  Level is read from the ${LOG_LEVEL} substitution variable, falling back
  to INFO. Logback resolves variables against JVM system properties first,
  then OS environment variables. Bootstrap's static initializer copies
  LOG_LEVEL out of .env into a system property *before* any logger is
  constructed, so editing .env and restarting is enough to flip the level.

  Precedence (first match wins):
    1. -DLOG_LEVEL=... JVM flag (in JAVA_OPTS)
    2. $LOG_LEVEL OS environment variable
    3. LOG_LEVEL in .env (bridged by dev.homeology.dinoworld.config.EarlyLogConfig)
    4. INFO (default in this file)

  Runtime changes via /debug log set <logger> <level> aren't persisted;
  /debug log reset re-reads this file via JoranConfigurator (which picks
  up the same system property again).
-->
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <!-- withJansi=false: Windows 10+ handles ANSI natively. Jansi can
             corrupt UTF-8 output on modern terminals. -->
        <withJansi>false</withJansi>
        <encoder>
            <pattern>%cyan(%d{HH:mm:ss.SSS}) [%thread]%X{tags} %highlight(%-5level) %boldWhite(%logger{36}) - %msg%n
            </pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/bot.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/bot.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread]%X{tags} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Pin JDA at INFO so DEBUG on root doesn't drown the log in gateway chatter. -->
    <logger name="net.dv8tion.jda" level="INFO"/>
    <!-- HikariCP is verbose at DEBUG; pin to INFO. -->
    <logger name="com.zaxxer.hikari" level="INFO"/>

    <root level="${LOG_LEVEL:-INFO}">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
