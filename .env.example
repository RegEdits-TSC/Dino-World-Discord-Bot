# ─── Dino-World configuration ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# On Linux, after editing: `chmod 600 .env`

# Discord bot token from https://discord.com/developers/applications
# REQUIRED.
BOT_TOKEN=replace-me

# Discord user ID of the developer/owner. Bypasses ALL permission checks
# and is the recipient of error-report DMs. Right-click your name in
# Discord (with developer mode on) → Copy User ID.
# REQUIRED.
DEVELOPER_ID=000000000000000000

# Filesystem path (relative to working dir or absolute) for the SQLite DB.
# The parent directory is auto-created on startup.
DATABASE_PATH=data/dinoworld.db

# Optional: a guild ID. If set, slash commands register to this single
# guild only (instant updates, ideal for development). If blank, commands
# register globally (Discord caches global commands for up to ~1 hour).
DEV_GUILD_ID=

# Root logger level: TRACE, DEBUG, INFO, WARN, ERROR, OFF.
# Applied at boot — edit and restart to switch (e.g. flip to DEBUG for
# verbose troubleshooting, back to INFO when done). Override precedence:
#   -DLOG_LEVEL=... in JAVA_OPTS > $LOG_LEVEL env var > this line.
# /debug log set ROOT <level> changes the level at runtime without
# restarting; /debug log reset re-reads logback.xml (which itself
# resolves back to whatever this evaluates to at boot).
LOG_LEVEL=INFO

# Bot presence shown in Discord. Activity type ∈ PLAYING, WATCHING,
# LISTENING, COMPETING, NONE. NONE (or empty) = no activity displayed.
BOT_ACTIVITY_TYPE=NONE
BOT_ACTIVITY_TEXT=

# Comma-separated list of module names to skip at startup. The module
# code stays in the jar but onLoad/onEnable are never called.
# Example: DISABLED_MODULES=economy,fun
DISABLED_MODULES=
